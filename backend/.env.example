# ──────────────────────────────────────────────
# LOL Skin Collector — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────

# Flask secret key (use a long random string in production)
SECRET_KEY=change-me-to-something-secret

# Supabase PostgreSQL connection string
# Find it at: Supabase Dashboard → Your Project → Settings → Database → Connection string → URI
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
